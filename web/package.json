{
  "name": "naos",
  "version": "0.1.0",
  "license": "MIT",
  "type": "module",
  "source": "src/index.ts",
  "main": "dist/main.js",
  "exports": {
    ".": "./dist/main.js",
    "./serial-node": "./dist/serial-node.js"
  },
  "targets": {
    "main": {
      "source": "src/index.ts"
    },
    "serial-node": {
      "source": "src/serial-node.ts",
      "distDir": "dist",
      "outputFormat": "esmodule",
      "context": "node",
      "isLibrary": true
    }
  },
  "scripts": {
    "run": "parcel test.html --dist-dir .parcel-dist",
    "build": "parcel build",
    "typecheck": "tsc --noEmit",
    "fmt": "prettier --write .",
    "test": "node --import tsx --test test/**/*.test.ts",
    "test:watch": "node --import tsx --test --watch test/**/*.test.ts",
    "test-node": "tsx test-node.ts"
  },
  "dependencies": {
    "@serialport/parser-readline": "^13.0.0",
    "async-await-queue": "^2.1.4",
    "serialport": "^13.0.0"
  },
  "devDependencies": {
    "@parcel/transformer-sass": "2.16.4",
    "@types/node": "^25.6.0",
    "@types/w3c-web-serial": "^1.0.8",
    "@types/web-bluetooth": "^0.0.21",
    "parcel": "^2.16.4",
    "prettier": "^3.8.2",
    "tsx": "^4.0.0",
    "typescript": "^6.0.2",
    "webbluetooth": "^3.6.0"
  }
}
